{
    "name": "sakibalimalik/laravel-blog",
    "description": "A reusable blog module for Laravel applications",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Sakib Ali Malik",
            "email": "sakibalimalik@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "SakibAliMalik\\Blog\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SakibAliMalik\\Blog\\BlogServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
